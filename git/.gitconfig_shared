[alias]
    fk = commit --amend --no-edit
    st = status -sb
    lg = log --graph --date=format:'%Y-%m-%d %H:%M' \
         --pretty=format:'%C(auto)%h%d %s %Cblue(%ad)%Creset'
    last = log -p -1

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections

[merge]
    conflictStyle = zdiff3
    tool = meld
